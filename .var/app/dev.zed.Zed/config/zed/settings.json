{
  "ui_font_size": 16,
  "buffer_font_size": 16,
  "cli_default_open_behavior": "new_window",
  "theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Mocha",
  },
  "edit_predictions": {
    "mode": "subtle",
  },
  "terminal": {
    "shell": {
      "program": "fish",
    },
  },
  "auto_install_extensions": {
    // themes
    "catppuccin": true,
    "rose-pine-theme": true,
    "alabaster": true,
    // core
    "git-firefly": true,
    "toml": true,
    "sql": true,
    // other
    "codebook": true,
    "deno": true,
    "graphql": true,
    "astro": true,
    "vue": true,
  },
  "lsp": {
    "deno": {
      "settings": {
        "deno": {
          "enable": true,
        },
      },
    },
  },
  "language_servers": ["...", "!tailwindcss-language-server"],
  "languages": {
    "JavaScript": {
      "language_servers": ["deno", "!typescript-language-server"],
      "formatter": "language_server",
    },
    "TypeScript": {
      "language_servers": ["deno", "!typescript-language-server"],
      "formatter": "language_server",
    },
    "TSX": {
      "language_servers": ["deno", "!typescript-language-server"],
      "formatter": "language_server",
    },
  },
}
